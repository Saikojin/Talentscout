{
    "LinkedIn": {
        "search_url": "https://www.linkedin.com/jobs/search?keywords={search_term}&location={location}",
        "job_card_selector": ".base-card",
        "title_selector": ".base-search-card__title",
        "company_selector": ".base-search-card__subtitle",
        "job_url_selector": ".base-card__full-link"
    },
