{
  "name": "talentscout",
  "version": "1.0.0",
  "description": "Resume-as-code portfolio landing page with MCP server and ATS adapters",
  "main": "compiler/build.js",
  "type": "module",
  "scripts": {
    "validate": "node compiler/validate.js",
    "build": "node compiler/build.js",
    "build:pdf": "node compiler/build.js --pdf",
    "ats:greenhouse": "node compiler/adapters/greenhouse.js",
    "ats:workday": "node compiler/adapters/workday.js",
    "mcp": "cd mcp-server && npx tsx src/index.ts",
    "mcp:stdio": "cd mcp-server && npx tsx src/index.ts",
    "deploy:stage": "node scripts/deploy-web.js",
    "deploy": "npm run build && npm run deploy:stage && npx gh-pages -d deploy",
    "build:docx": "node compiler/build.js --docx",
    "dev": "node scripts/watch.js",
    "dev:browser": "concurrently \"npm run dev\" \"browser-sync start --server web --files dist\"",
    "test": "npx vitest run --reporter=default --reporter=./tests/spacetime-reporter.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "docx": "^9.7.1",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "gh-pages": "^6.3.0",
    "vitest": "^1.6.0"
  }
}
